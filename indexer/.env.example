# Arc RPC (Ponder keys the URL by chain id). A dedicated provider is strongly
# recommended over the public endpoint for the historical backfill.
PONDER_RPC_URL_5042002=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002

# Postgres for the indexed data. Use a SEPARATE Neon database/branch from the
# app's DATABASE_URL so a re-sync (ponder db reset) never touches app tables.
DATABASE_URL=postgres://user:pass@host/arcade_indexer

# Arcade contracts (Arc testnet current gen -- from web/public/deployments.json).
LAUNCHPAD_ADDRESS=0xB6c9bD475EE6596342c1c49DE6513C9451f8C7e4
V3_FACTORY_ADDRESS=0x7E875574062613de8A4d43cDA21628368914c01A
USDC_ADDRESS=0x3600000000000000000000000000000000000000

# Deploy blocks = where each backfill starts. The launchpad is the CURRENT gen
# (recent); the V3 factory is REUSED across gens (older) so its pools predate
# the launchpad -- hence two separate blocks. Find either with:
#   node scripts/find-start-block.mjs <address> <rpcUrl>
# (values below are the Arc-testnet current gen, found 2026-07-16)
LAUNCHPAD_START_BLOCK=52095981
V3_START_BLOCK=49467254
