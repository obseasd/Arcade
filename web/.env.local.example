# =============================================================================
# Arcade frontend env reference.
#
# CLIENT vars are NEXT_PUBLIC_*, shipped to the browser.
# SERVER vars are read only from app/api/ routes — never NEXT_PUBLIC_.
# All vars are OPTIONAL unless flagged REQUIRED.
# =============================================================================

# ---- REQUIRED ---------------------------------------------------------------

# WalletConnect Cloud project ID (required by RainbowKit).
# Get one at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Chain selection: "local" (Anvil) or "arc" (Arc testnet).
NEXT_PUBLIC_DEFAULT_CHAIN=local

# ---- CONTRACT ADDRESSES (client) --------------------------------------------
# Filled in after running the deploy script — mirror web/public/deployments.json

NEXT_PUBLIC_USDC_ADDRESS=
NEXT_PUBLIC_V2_FACTORY_ADDRESS=
NEXT_PUBLIC_V2_ROUTER_ADDRESS=
NEXT_PUBLIC_V2_ZAP_ADDRESS=
NEXT_PUBLIC_LAUNCHPAD_ADDRESS=
NEXT_PUBLIC_MULTISWAP_ADDRESS=
NEXT_PUBLIC_V3_FACTORY_ADDRESS=
NEXT_PUBLIC_V3_LOCKER_ADDRESS=
NEXT_PUBLIC_V3_ROUTER_ADDRESS=
NEXT_PUBLIC_V3_QUOTER_ADDRESS=
NEXT_PUBLIC_V3_NPM_ADDRESS=
NEXT_PUBLIC_V3_ZAP_ADDRESS=
NEXT_PUBLIC_TOKEN_VAULT_ADDRESS=
NEXT_PUBLIC_TWITTER_ESCROW_ADDRESS=
NEXT_PUBLIC_SEED_ETH_ADDRESS=

# Optional — WETH for POOL_WETH Clanker launches
NEXT_PUBLIC_WETH_ADDRESS=

# ---- V4 stack (optional) ----------------------------------------------------
NEXT_PUBLIC_V4_ENABLED=
NEXT_PUBLIC_V4_POOL_MANAGER_ADDRESS=
NEXT_PUBLIC_V4_LAUNCHPAD_ADDRESS=
NEXT_PUBLIC_V4_HOOK_ADDRESS=
NEXT_PUBLIC_V4_STATE_VIEW_ADDRESS=
NEXT_PUBLIC_V4_QUOTER_ADDRESS=
NEXT_PUBLIC_V4_ROUTER_ADDRESS=
NEXT_PUBLIC_ARCADE_HOOK_ADDRESS=
NEXT_PUBLIC_LOCKED_VAULT_ADDRESS=

# ---- Orbs limit-order stack (optional) --------------------------------------
NEXT_PUBLIC_ORBS_TWAP_ADDRESS=
NEXT_PUBLIC_ORBS_EXCHANGE_V2_ADDRESS=
NEXT_PUBLIC_ORBS_LENS_ADDRESS=

# ---- Frontend config (optional) ---------------------------------------------

# Comma-separated lowercase addresses surfaced at the top of /launchpad.
NEXT_PUBLIC_FEATURED_TOKENS=

# Browser-side fallback ENS RPC. Empty = client doesn't ping mainnet directly;
# /api/ens/* server-side hops are used instead (recommended — adblockers
# routinely block public ETH RPCs from the browser).
NEXT_PUBLIC_MAINNET_RPC=

# Override IPFS gateway. Defaults to ipfs.io + cloudflare-ipfs.com quorum.
NEXT_PUBLIC_IPFS_GATEWAY=

# Public site URL used for OG tags + Twitter callbacks (override in prod).
NEXT_PUBLIC_SITE_URL=

# ---- SERVER-ONLY secrets ----------------------------------------------------
# These MUST NOT be NEXT_PUBLIC_. Set them in Vercel project env scoped to
# Production + Preview, never in client code.

# Pinata IPFS pinning (uploads launchpad metadata + creator avatars)
PINATA_JWT=

# Backend signer for Twitter Escrow EIP-712 claim authorisations.
# Private key, hex with 0x prefix. Generates the signature in
# app/api/twitter-callback. Rotate before mainnet.
ARCADE_BACKEND_PRIVATE_KEY=

# Twitter OAuth (confidential client)
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# 32+ char random string used to HMAC OAuth state cookies + claim payload.
# Required for /api/twitter-login and /api/claim/payload to operate.
ARCADE_OAUTH_STATE_SECRET=

# Optional dedicated mainnet RPC for server-side ENS resolution. When unset
# the routes fall back to a list of public providers (rate-limit prone).
MAINNET_RPC=
