# WalletConnect Cloud project ID (required by RainbowKit) — https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Chain selection: "local" (Anvil) or "arc" (Arc testnet)
NEXT_PUBLIC_DEFAULT_CHAIN=local

# Contract addresses — filled in after running the deploy script
NEXT_PUBLIC_USDC_ADDRESS=
NEXT_PUBLIC_V2_FACTORY_ADDRESS=
NEXT_PUBLIC_V2_ROUTER_ADDRESS=
NEXT_PUBLIC_LAUNCHPAD_ADDRESS=

# Optional — IPFS metadata uploads (server-side)
PINATA_JWT=
