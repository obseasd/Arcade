# --- Used by script/DeployTestnet.s.sol ---
# Real Arc USDC ERC20 (native gas token)
ARC_USDC_ADDRESS=0x3600000000000000000000000000000000000000
# WETH on Arc, used as the quote token for POOL_WETH Clanker launches (non-official for now)
ARC_WETH_ADDRESS=0x9570EBA9eE39Aa4933f64d6add280faAB289a847
# Platform fee receiver (curve fees + post-migration royalty + Clanker 20% + 3 USDC creation fee).
# Defaults to the deployer if unset.
TREASURY_ADDRESS=

# NOTE: launchpad economics (creation fee = 3 USDC, migration at 20,000 USDC,
# virtual reserves, fee splits) are hardcoded constants in ArcadeLaunchpad.sol.
# They are NOT read from env. Edit the contract to change them.

# --- Used by script/DeployTwitterEscrow.s.sol ---
# Address of the already-deployed ArcadeV3Locker (from the latest DeployTestnet run).
ARCADE_V3_LOCKER_ADDRESS=0x60b23CEeA70c3846AC5f9b32E1f8598136E3E569
# Public address of the off-chain signing wallet whose key sits in Vercel as
# ARCADE_BACKEND_PRIVATE_KEY. The escrow trusts this signer for Twitter claims.
